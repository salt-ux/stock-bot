APP_ENV=local
APP_PORT=8080
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=stock
DB_PASSWORD=stockpass
DB_NAME=stockbot
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
KIWOOM_BASE_URL=
KIWOOM_TOKEN_PATH=/oauth2/token
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
BROKER_PROVIDER=kiwoom
MARKET_PROVIDER=mock
MARKET_CACHE_TTL_SECONDS=5
KIWOOM_MARKET_QUOTE_PATH=/api/dostk/stkinfo
KIWOOM_MARKET_QUOTE_API_ID=ka10001
KIWOOM_MARKET_CANDLE_PATH=/api/dostk/chart
KIWOOM_MARKET_CANDLE_MINUTE_API_ID=ka10080
KIWOOM_MARKET_CANDLE_DAILY_API_ID=ka10081
KIWOOM_MARKET_SYMBOL_PATH=/api/dostk/stkinfo
KIWOOM_MARKET_SYMBOL_LIST_API_ID=ka10099
KIWOOM_MARKET_SYMBOL_SEARCH_API_ID=ka10100
KIWOOM_MARKET_SYMBOL_CACHE_TTL_SECONDS=600
KIWOOM_MARKET_USE_WEBSOCKET=true
KIWOOM_MARKET_WS_URL=
KIWOOM_MARKET_WS_PATH=/api/dostk/websocket
KIWOOM_MARKET_WS_QUOTE_TR=0B
TRADING_INITIAL_CASH=50000000
RISK_MAX_POSITION_NOTIONAL=10000000
RISK_DAILY_LOSS_LIMIT=1000000
RISK_DUPLICATE_WINDOW_SECONDS=30
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_MARKET_OPEN_CRON="0 9 * * 1-5"
SCHEDULER_AUTOTRADE_CRON="30 10 * * 1-5"
