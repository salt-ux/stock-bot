SCHEDULER_AUTOTRADE_INTERVAL=1d
SCHEDULER_AUTOTRADE_LIMIT=60
SCHEDULER_AUTOTRADE_STRATEGY=infinite_buy
SCHEDULER_AUTOTRADE_QTY=1
SCHEDULER_SMA_SHORT=5
SCHEDULER_SMA_LONG=20
SCHEDULER_INFINITE_BUY_COUNT=0
SCHEDULER_INFINITE_AVG_PRICE=0
SCHEDULER_INFINITE_ALLOCATION=0
